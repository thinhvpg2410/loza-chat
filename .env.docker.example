# Copy to .env in the repo root for docker compose variable substitution:
#   cp .env.docker.example .env

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

# URLs as seen from the host browser (mock uploads / avatars)
API_PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated origins allowed by the API (include your web URL)
CORS_ORIGIN=http://localhost:3001

# true = mock storage on the API; false = configure S3_* on the api service
STORAGE_MOCK=true
