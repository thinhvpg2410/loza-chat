generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendRequestStatus {
  pending
  accepted
  rejected
  cancelled
}

enum ConversationType {
  direct
  group
}

enum ConversationMemberRole {
  owner
  admin
  member
}

enum MessageType {
  text
  image
  file
  voice
  video
  other
  system
}

enum UploadSessionStatus {
  pending
  uploaded
  failed
  expired
}

/// Shared taxonomy for upload sessions and attachments (extensible for stickers, etc.)
enum MediaKind {
  image
  file
  voice
  video
  other
}

model User {
  id            String   @id @default(uuid())
  phoneNumber   String   @unique @map("phone_number")
  username      String?  @unique
  displayName   String   @default("") @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  statusMessage String?  @map("status_message")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  devices                  UserDevice[]
  refreshTokens            RefreshToken[]
  sentFriendRequests       FriendRequest[]      @relation("SentFriendRequests")
  receivedFriendRequests   FriendRequest[]      @relation("ReceivedFriendRequests")
  friendshipsAsOne         Friendship[]         @relation("FriendshipsUserOne")
  friendshipsAsTwo         Friendship[]         @relation("FriendshipsUserTwo")
  blocksInitiated          Block[]              @relation("BlocksInitiated")
  blocksReceived           Block[]              @relation("BlocksReceived")
  conversationsCreated     Conversation[]       @relation("ConversationCreatedBy")
  conversationMembers      ConversationMember[]
  messagesSent             Message[]
  directConversationsAsOne Conversation[]       @relation("DirectConversationsUserOne")
  directConversationsAsTwo Conversation[]       @relation("DirectConversationsUserTwo")
  uploadSessions           UploadSession[]
  attachmentsUploaded      Attachment[]

  @@map("users")
}

model OtpRequest {
  id          String    @id @default(uuid())
  phoneNumber String    @map("phone_number")
  otpCodeHash String    @map("otp_code_hash")
  purpose     String
  expiredAt   DateTime  @map("expired_at")
  verifiedAt  DateTime? @map("verified_at")
  attempts    Int       @default(0)
  resendCount Int       @default(0) @map("resend_count")
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([phoneNumber, createdAt])
  @@map("otp_requests")
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  deviceId   String   @map("device_id")
  platform   String
  appVersion String   @map("app_version")
  deviceName String?  @map("device_name")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("user_devices")
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  userDeviceId String    @map("user_device_id")
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userDevice UserDevice @relation(fields: [userDeviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userDeviceId])
  @@map("refresh_tokens")
}

model FriendRequest {
  id          String              @id @default(uuid())
  senderId    String              @map("sender_id")
  receiverId  String              @map("receiver_id")
  status      FriendRequestStatus
  message     String?
  respondedAt DateTime?           @map("responded_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  // DB: partial unique index friend_requests_one_pending_per_pair (see migrations) — one pending per unordered pair

  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([senderId, receiverId, status])
  @@map("friend_requests")
}

/// Invariant: userOneId < userTwoId (lexicographic). Enforced by DB CHECK + sortUserPair().
/// When adding direct-message conversations, prefer linking via friendshipId or a dedicated conversation table.
model Friendship {
  id        String   @id @default(uuid())
  userOneId String   @map("user_one_id")
  userTwoId String   @map("user_two_id")
  createdAt DateTime @default(now()) @map("created_at")

  userOne User @relation("FriendshipsUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo User @relation("FriendshipsUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)

  @@unique([userOneId, userTwoId])
  @@index([userOneId])
  @@index([userTwoId])
  @@map("friendships")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

/// Invariant for type=direct: directUserOneId < directUserTwoId (lexicographic). Enforced by DB CHECK + sortUserPair().
model Conversation {
  id              String           @id @default(uuid())
  type            ConversationType
  title           String?
  avatarUrl       String?          @map("avatar_url")
  createdById     String?          @map("created_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  lastMessageId   String?          @unique @map("last_message_id")
  directUserOneId String?          @map("direct_user_one_id")
  directUserTwoId String?          @map("direct_user_two_id")

  createdBy     User?                @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  directUserOne User?                @relation("DirectConversationsUserOne", fields: [directUserOneId], references: [id], onDelete: Restrict)
  directUserTwo User?                @relation("DirectConversationsUserTwo", fields: [directUserTwoId], references: [id], onDelete: Restrict)
  lastMessage   Message?             @relation("ConversationLastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)
  members       ConversationMember[]
  messages      Message[]
  attachments   Attachment[]

  @@index([updatedAt(sort: Desc)])
  @@map("conversations")
}

model ConversationMember {
  id                     String                  @id @default(uuid())
  conversationId         String                  @map("conversation_id")
  userId                 String                  @map("user_id")
  role                   ConversationMemberRole? @map("role")
  joinedAt               DateTime                @default(now()) @map("joined_at")
  lastReadMessageId      String?                 @map("last_read_message_id")
  lastDeliveredMessageId String?                 @map("last_delivered_message_id")
  mutedUntil             DateTime?               @map("muted_until")
  createdAt              DateTime                @default(now()) @map("created_at")

  conversation         Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage      Message?     @relation("MemberLastRead", fields: [lastReadMessageId], references: [id], onDelete: SetNull)
  lastDeliveredMessage Message?     @relation("MemberLastDelivered", fields: [lastDeliveredMessageId], references: [id], onDelete: SetNull)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

/// Tracks a client-direct upload to object storage. Bytes never touch NestJS.
model UploadSession {
  id               String              @id @default(uuid())
  userId           String              @map("user_id")
  storageKey       String              @map("storage_key")
  bucket           String
  mimeType         String              @map("mime_type")
  originalFileName String              @map("original_file_name")
  fileSize         BigInt              @map("file_size")
  uploadType       MediaKind           @map("upload_type")
  status           UploadSessionStatus
  expiresAt        DateTime            @map("expires_at")
  completedAt      DateTime?           @map("completed_at")
  metadataJson     Json?               @map("metadata_json")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachment  Attachment?

  @@index([userId, status])
  @@index([expiresAt])
  @@map("upload_sessions")
}

/// Binary metadata for a message. Bound to at most one message; reuse only before binding (explicit design).
model Attachment {
  id              String    @id @default(uuid())
  conversationId  String?   @map("conversation_id")
  messageId       String?   @map("message_id")
  uploadedById    String    @map("uploaded_by_id")
  uploadSessionId String?   @unique @map("upload_session_id")
  storageKey      String    @map("storage_key")
  bucket          String
  mimeType        String    @map("mime_type")
  originalFileName String   @map("original_file_name")
  fileSize        BigInt    @map("file_size")
  attachmentType  MediaKind @map("attachment_type")
  width           Int?
  height          Int?
  durationSeconds Int?      @map("duration_seconds")
  thumbnailKey    String?   @map("thumbnail_key")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  conversation  Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message       Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  uploadedBy    User          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  uploadSession UploadSession? @relation(fields: [uploadSessionId], references: [id], onDelete: SetNull)

  @@index([uploadSessionId])
  @@index([messageId])
  @@index([uploadedById])
  @@index([conversationId])
  @@map("attachments")
}

model Message {
  id               String      @id @default(uuid())
  conversationId   String      @map("conversation_id")
  senderId         String      @map("sender_id")
  clientMessageId  String      @map("client_message_id")
  type             MessageType
  content          String?
  metadataJson     Json?       @map("metadata_json")
  replyToMessageId String?     @map("reply_to_message_id")
  deletedAt        DateTime?   @map("deleted_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  conversation           Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender                 User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo                Message?             @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies                Message[]            @relation("MessageReplies")
  lastMessageFor         Conversation?        @relation("ConversationLastMessage")
  lastReadByMembers      ConversationMember[] @relation("MemberLastRead")
  lastDeliveredByMembers ConversationMember[] @relation("MemberLastDelivered")
  attachments            Attachment[]

  @@unique([conversationId, senderId, clientMessageId])
  @@index([conversationId, createdAt(sort: Desc), id(sort: Desc)])
  @@map("messages")
}
