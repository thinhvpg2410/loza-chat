# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/loza_chat?schema=public"

# App
NODE_ENV=development
PORT=3000

# Public URL clients use to reach this API (phones/emulators: use LAN IP). Required for STORAGE_MOCK uploads + avatar URLs.
# API_PUBLIC_BASE_URL=http://192.168.1.10:3000

# CORS: comma-separated browser origins (Expo web, Next.js, etc.). Omit in dev to allow reflected origin.
# CORS_ORIGIN=http://localhost:8081,http://127.0.0.1:8081

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30
JWT_OTP_PROOF_EXPIRES_IN=15m

# Object storage
# STORAGE_MOCK=true  → no S3; presigned URL trỏ về API (PUT /uploads/mock-upload/...). Bucket sẽ KHÔNG có file.
# STORAGE_MOCK=false → cần S3/R2 đủ biến bên dưới; file nằm trên bucket thật.
# STORAGE_MOCK=true
# S3_BUCKET=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=          # optional, ví dụ Cloudflare R2
# S3_PUBLIC_BASE_URL=   # optional CDN/public origin cho URL avatar
#
# Expo Web / trình duyệt PUT thẳng lên S3: bucket PHẢI bật CORS (Console → bucket → Permissions → Cross-origin resource sharing).
# Ví dụ (thêm origin production khi deploy):
# [{"AllowedHeaders":["*"],"AllowedMethods":["GET","PUT","HEAD"],"AllowedOrigins":["http://localhost:8081","http://127.0.0.1:8081"],"ExposeHeaders":["ETag","x-amz-checksum-crc32","x-amz-sdk-checksum-algorithm"],"MaxAgeSeconds":3000}]

# OTP (DB-backed, no Redis)
OTP_EXPIRES_MINUTES=2
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_PHONE_WINDOW=5
OTP_RATE_WINDOW_MINUTES=15
OTP_MAX_RESENDS_PER_ACTIVE_CODE=3
