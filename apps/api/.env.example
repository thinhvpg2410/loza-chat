# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/loza_chat?schema=public"

# App
NODE_ENV=development
PORT=3000

# Public URL clients use to reach this API (phones/emulators: use LAN IP). Required for STORAGE_MOCK uploads + avatar URLs.
# API_PUBLIC_BASE_URL=http://192.168.1.10:3000

# CORS: comma-separated browser origins (Expo web, Next.js, etc.). Omit in dev to allow reflected origin.
# CORS_ORIGIN=http://localhost:8081,http://127.0.0.1:8081

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30
JWT_OTP_PROOF_EXPIRES_IN=15m

# OTP (DB-backed, no Redis)
OTP_EXPIRES_MINUTES=2
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_PHONE_WINDOW=5
OTP_RATE_WINDOW_MINUTES=15
OTP_MAX_RESENDS_PER_ACTIVE_CODE=3
